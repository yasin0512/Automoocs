# ════════════════════════════════════════════════════════════════
# MOOCs Auto-Generation System — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── OpenAI API Key (optional — only needed if using GPT-4o fallback) ──
# Leave empty to use Ollama (local LLM, privacy-first, no key needed)
OPENAI_API_KEY=

# ── Ollama URL (default: localhost:11434) ──────────────────────
# Change if running Ollama on a different host/port
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Whisper Model Size ────────────────────────────────────────
# CPU: "base" (auto-selected if no CUDA) | GPU: "large-v3"
# Override here to force a specific size
WHISPER_MODEL=large-v3

# ── Stable Diffusion WebUI URL ────────────────────────────────
# Only needed for Slide Strategy B (no user images provided)
# Start SD WebUI with: ./webui.sh --api --listen
SD_WEBUI_URL=http://127.0.0.1:7860

# ── wav2lip directory (real mode Step 6) ──────────────────────
# Path to cloned Wav2Lip repository
WAV2LIP_DIR=Wav2Lip

# ── Output directory ──────────────────────────────────────────
OUTPUT_DIR=output

# ── Server config ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
